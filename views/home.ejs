<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>
</head>
<body>

    <h1>URL Shortener</h1>

    <form method="POST" action="/urls">
        <label>Enter your original URL</label><br><br>

        <input
            type="text"
            name="url"
            placeholder="https://example.com"
            required
        >

        <button type="submit">Generate Short URL</button>
    </form>

    <% if (typeof id !== "undefined") { %>
        <h3>Your Short URL:</h3>
        <a href="/<%= id %>">
            http://localhost:8001/<%= id %>
        </a>
    <% } %>

    <br><br>

    <% if (locals.urls && locals.urls.length > 0) { %>
        <table border="1" cellpadding="10" cellspacing="0">
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Original URL</th>
                    <th>Short URL</th>
                </tr>
            </thead>

            <tbody>
                <% locals.urls.forEach((url, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>

                        <td>
                            <a href="<%= url.redirectURL %>" target="_blank">
                                <%= url.redirectURL %>
                            </a>
                        </td>

                        <td>
                            <a href="/<%= url.shortID %>">
                                http://localhost:8001/<%= url.shortID %>
                            </a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <p>No URLs found.</p>
    <% } %>

</body>
</html>